generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum StaffRole {
  SUPER_ADMIN
  GENERAL_ADMIN
  CASE_MANAGER
  MISSION_VERIFIER
  FINANCE_MANAGER
}

enum BeneficiaryStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CaseStage {
  SUBMITTED
  VERIFICATION
  APPROVED
  PROVIDER_SELECTION
  PAYMENT
  IMPACT
  CLOSED
  REJECTED
  ON_HOLD
}

enum Urgency {
  NORMAL
  HIGH
  URGENT
}

enum SupplierVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  ASSIGNED
  TRANSITIONED
  APPROVED
  REJECTED
  VIEWED
  EXPORTED
  LOGIN
  LOGOUT
  TENANT_SWITCHED
}

model User {
  id            String           @id @default(uuid()) @db.Uuid
  authSubject   String           @unique
  email         String           @unique
  displayName   String
  phone         String?
  staffType     String           @default("EMPLOYEE")
  title         String?
  organization  String?
  passwordHash  String?
  role          StaffRole        @default(CASE_MANAGER)
  active        Boolean          @default(true)
  managedCases  Case[]           @relation("CaseManager")
  verifications Case[]           @relation("CaseVerifier")
  verifiedSuppliers Supplier[]    @relation("SupplierVerifier")
  transitions   CaseTransition[]
  auditEvents   AuditEvent[]     @relation("AuditActor")
  uploadedDocuments SupportingDocument[] @relation("UploadedDocuments")
  lastLoginAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Beneficiary {
  id            String            @id @default(uuid()) @db.Uuid
  referenceCode String            @unique
  legalName     String
  preferredName String
  email         String?
  phone         String?
  city          String
  region        String
  country       String            @default("IN") @db.Char(2)
  status        BeneficiaryStatus @default(ACTIVE)
  cases         Case[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([preferredName])
  @@index([phone])
}

model Supplier {
  id                   String                     @id @default(uuid()) @db.Uuid
  name                 String
  serviceType          String
  contactName          String?
  email                String?
  phone                String?
  city                 String
  region               String
  notes                String?
  active               Boolean                    @default(true)
  verificationStatus   SupplierVerificationStatus @default(PENDING)
  verificationNotes    String?
  verifiedAt           DateTime?
  verifiedById         String?                    @db.Uuid
  verifiedBy           User?                      @relation("SupplierVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([name])
  @@index([serviceType])
  @@index([active])
  @@index([verificationStatus])
  @@index([verifiedById])
}

model RolePermission {
  id         String    @id @default(uuid()) @db.Uuid
  role       StaffRole
  permission String
  enabled    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([role, permission])
  @@index([role])
  @@index([permission])
}

model SupportingDocument {
  id           String   @id @default(uuid()) @db.Uuid
  entityType   String
  entityId     String   @db.Uuid
  label        String?
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  uploadedById String?  @db.Uuid
  uploadedBy   User?    @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([uploadedById])
}

model Case {
  id                   String           @id @default(uuid()) @db.Uuid
  beneficiaryId        String           @db.Uuid
  caseNumber           String           @unique
  title                String
  category             String
  description          String
  requestedAmountMinor BigInt
  approvedAmountMinor  BigInt?
  currency             String           @default("INR") @db.Char(3)
  urgency              Urgency          @default(NORMAL)
  stage                CaseStage        @default(SUBMITTED)
  caseManagerId        String?          @db.Uuid
  verifierId           String?          @db.Uuid
  beneficiary          Beneficiary      @relation(fields: [beneficiaryId], references: [id], onDelete: Restrict)
  caseManager          User?            @relation("CaseManager", fields: [caseManagerId], references: [id], onDelete: SetNull)
  verifier             User?            @relation("CaseVerifier", fields: [verifierId], references: [id], onDelete: SetNull)
  transitions          CaseTransition[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  closedAt             DateTime?

  @@index([stage])
  @@index([beneficiaryId])
  @@index([caseManagerId])
  @@index([verifierId])
}

model CaseCategory {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
}

model IndiaState {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String   @unique
  kind      String   @default("STATE")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  cities    IndiaCity[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

model IndiaCity {
  id        String     @id @default(uuid()) @db.Uuid
  stateId   String     @db.Uuid
  name      String
  active    Boolean    @default(true)
  sortOrder Int        @default(0)
  state     IndiaState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([stateId, name])
  @@index([stateId, active, sortOrder])
}

model CaseTransition {
  id          String     @id @default(uuid()) @db.Uuid
  caseId      String     @db.Uuid
  fromStage   CaseStage?
  toStage     CaseStage
  actorUserId String     @db.Uuid
  reason      String?
  case        Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actor       User       @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  createdAt   DateTime   @default(now())

  @@index([caseId, createdAt])
  @@index([actorUserId])
}

model AuditEvent {
  id          String      @id @default(uuid()) @db.Uuid
  actorUserId String?     @db.Uuid
  action      AuditAction
  entityType  String
  entityId    String
  summary     Json?
  requestId   String?
  actor       User?       @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
